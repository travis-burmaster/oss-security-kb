{"id":"GHSA-x2mc-8fgj-3wmr","summary":"Improper Input Validation in tar-fs","details":"A vulnerability was found in tar-fs before 1.16.2. An Arbitrary File Overwrite issue exists when extracting a tarball containing a hardlink to a file that already exists on the system, in conjunction with a later plain file with the same name as the hardlink. This plain file content replaces the existing file content.","aliases":["CVE-2018-20835"],"modified":"2023-11-08T04:00:12.892530Z","published":"2019-05-01T18:37:18Z","database_specific":{"github_reviewed":true,"severity":"HIGH","nvd_published_at":"2019-04-30T19:29:00Z","github_reviewed_at":"2019-05-01T18:25:25Z","cwe_ids":["CWE-20"]},"references":[{"type":"ADVISORY","url":"https://nvd.nist.gov/vuln/detail/CVE-2018-20835"},{"type":"WEB","url":"https://github.com/mafintosh/tar-fs/commit/06672828e6fa29ac8551b1b6f36c852a9a3c58a2"},{"type":"WEB","url":"https://hackerone.com/reports/344595"},{"type":"WEB","url":"https://github.com/mafintosh/tar-fs/compare/d590fc7...a35ce2f"}],"affected":[{"package":{"name":"tar-fs","ecosystem":"npm","purl":"pkg:npm/tar-fs"},"ranges":[{"type":"SEMVER","events":[{"introduced":"0"},{"fixed":"1.16.2"}]}],"database_specific":{"source":"https://github.com/github/advisory-database/blob/main/advisories/github-reviewed/2019/05/GHSA-x2mc-8fgj-3wmr/GHSA-x2mc-8fgj-3wmr.json"}}],"schema_version":"1.7.3","severity":[{"type":"CVSS_V3","score":"CVSS:3.0/AV:N/AC:L/PR:N/UI:N/S:U/C:N/I:H/A:N"}]}