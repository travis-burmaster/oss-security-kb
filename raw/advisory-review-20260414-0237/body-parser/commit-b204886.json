      "patch": "@@ -127,11 +127,16 @@ function createQueryParser (options) {\n  *\n  * @param {string} body\n  * @param {number} limit\n+ * @return {number|undefined} Returns undefined if limit exceeded\n  * @api private\n  */\n-\n function parameterCount (body, limit) {\n-  var len = body.split('&').length\n-\n-  return len > limit ? undefined : len - 1\n+  let count = 0\n+  let index = -1\n+  do {\n+    count++\n+    if (count > limit) return undefined // Early exit if limit exceeded\n+    index = body.indexOf('&', index + 1)\n+  } while (index !== -1)\n+  return count\n }"
