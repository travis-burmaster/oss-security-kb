ash"},"vulnerable_version_range":">= 3.7.0, < 4.17.19","first_patched_version":"4.17.19","vulnerable_functions":[]},{"package":{"ecosystem":"npm","name":"lodash-es"},"vulnerable_version_range":">= 3.7.0, < 4.17.20","first_patched_version":"4.17.20","vulnerable_functions":[]},{"package":{"ecosystem":"npm","name":"lodash.pick"},"vulnerable_version_range":">= 4.0.0, <= 4.4.0","first_patched_version":null,"vulnerable_functions":[]},{"package":{"ecosystem":"npm","name":"lodash.set"},"vulnerable_version_range":">= 3.7.0, <= 4.3.2","first_patched_version":null,"vulnerable_functions":[]},{"package":{"ecosystem":"npm","name":"lodash.setwith"},"vulnerable_version_range":"<= 4.3.2","first_patched_version":null,"vulnerable_functions":[]},{"package":{"ecosystem":"npm","name":"lodash.update"},"vulnerable_version_range":"<= 4.10.2","first_patched_version":null,"vulnerable_functions":[]},{"package":{"ecosystem":"npm","name":"lodash.updatewith"},"vulnerable_version_range":"<= 4.10.2","first_patched_version":null,"vulnerable_functions":[]},{"package":{"ecosystem":"rubygems","name":"lodash-rails"},"vulnerable_version_range":">= 3.7.0, < 4.17.19","first_patched_version":"4.17.19","vulnerable_functions":[]}],"cvss_severities":{"cvss_v3":{"vector_string":"CVSS:3.1/AV:N/AC:H/PR:N/UI:N/S:U/C:N/I:H/A:H","score":7.4},"cvss_v4":{"vector_string":null,"score":0.0}},"cwes":[{"cwe_id":"CWE-770","name":"Allocation of Resources Without Limits or Throttling"},{"cwe_id":"CWE-1321","name":"Improperly Controlled Modification of Object Prototype Attributes ('Prototype Pollution')"}],"credits":[{"user":{"login":"mitchell-codecov","id":88285871,"node_id":"MDQ6VXNlcjg4Mjg1ODcx","avatar_url":"https://avatars.githubusercontent.com/u/88285871?v=4","gravatar_id":"","url":"https://api.github.com/users/mitchell-codecov","html_url":"https://github.com/mitchell-codecov","followers_url":"https://api.github.com/users/mitchell-codecov/followers","following_url":"https://api.github.com/users/mitchell-codecov/following